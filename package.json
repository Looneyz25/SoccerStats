{
  "name": "soccer-stats",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/restart-next-dev.ps1",
    "dev:next": "next dev -p 3001",
    "dev:fresh": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/restart-next-dev.ps1",
    "dev:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/restart-next-dev.ps1 -NoStart",
    "dev:health": "node scripts/dev-health.js",
    "prebuild": "node -e \"console.log('Skipping public JSON; dashboard reads Firestore only')\"",
    "build": "node scripts/next-build-prod.js",
    "data:firebase": "npm run data:badges && node scripts/upload_match_data_to_firestore.mjs",
    "data:badges": "node scripts/cache_badges_to_firebase.mjs",
    "data:collect": "node scripts/run-python.js scripts/soccer_phases_routine.py",
    "data:refresh:local": "node scripts/run-python.js scripts/soccer_routine.py && npm.cmd run data:collect",
    "data:refresh": "node scripts/get-data-with-log.mjs",
    "data:refresh:results": "node scripts/get-data-with-log.mjs --results-only",
    "data:update": "npm.cmd run data:refresh",
    "data:get": "npm.cmd run data:refresh",
    "get:data": "npm.cmd run data:refresh",
    "get:data:results": "npm.cmd run data:refresh:results",
    "deploy:firebase": "npm.cmd run build && npx firebase-tools deploy --only hosting,firestore:rules,functions --project sports-predictions-f91fd",
    "firebase:serve": "npm.cmd run build && npx firebase-tools emulators:start --only hosting --project sports-predictions-f91fd",
    "audit:summary": "node scripts/audit_prediction_summary.js",
    "start": "next start"
  },
  "dependencies": {
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
